    "# Features we will use\n",
    "feature_columns = [\n",
    "    \"Return\", \"MA_5\", \"MA_10\", \"MA_20\",\n",
    "    \"Vol_10\", \"Vol_20\", \"RSI_14\", \"Volume\"\n",
    "]\n",
    "\n",
    "# Keep only needed columns + Ticker\n",
    "ml_df = full_data[feature_columns + [\"Target\", \"Ticker\"]].copy()\n",
    "\n",
    "# Drop any rows with missing values\n",
    "ml_df = ml_df.dropna()\n",
    "\n",
    "# Separate X and y\n",
    "X_num = ml_df[feature_columns].copy()\n",
    "y = ml_df[\"Target\"].copy()\n",
    "\n",
    "# One-hot encode ticker\n",
    "ticker_dummies = pd.get_dummies(ml_df[\"Ticker\"], prefix=\"Ticker\")\n",
    "\n",
    "# Combine numeric features + ticker dummies\n",
    "X = pd.concat([X_num, ticker_dummies], axis=1)\n",
    "\n",
    "# Flatten column names to simple strings (avoid MultiIndex issues)\n",
    "if isinstance(X.columns, pd.MultiIndex):\n",
    "    X.columns = [\"_\".join(map(str, col)) for col in X.columns]\n",
    "else:\n",
    "    X.columns = X.columns.astype(str)\n",
