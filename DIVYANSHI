    "# List of green/renewable-related tickers (you can change later)\n",
    "TICKERS = [\"TSLA\", \"NEE\", \"ENPH\", \"FSLR\", \"RUN\", \"VWS.CO\"]\n",
    "\n",
    "START_DATE = \"2018-01-01\"\n",
    "END_DATE = \"2024-12-31\"\n",
    "\n",
    "\n",
    "def compute_rsi(prices, period=14):\n",
    "    \"\"\"\n",
    "    Robust RSI: works even if input is Series, DataFrame, or numpy array.\n",
    "    \"\"\"\n",
    "    values = np.asarray(prices).reshape(-1)   # force 1D\n",
    "    idx = getattr(prices, \"index\", None)\n",
    "\n",
    "    s = pd.Series(values, index=idx).astype(float)\n",
    "\n",
    "    delta = s.diff()\n",
    "    gain = delta.where(delta > 0, 0.0)\n",
    "    loss = -delta.where(delta < 0, 0.0)\n",
    "\n",
    "    avg_gain = gain.rolling(window=period).mean()\n",
    "    avg_loss = loss.rolling(window=period).mean()\n",
    "\n",
    "    rs = avg_gain / avg_loss\n",
    "    rsi = 100 - (100 / (1 + rs))\n",
    "    return rsi\n",
    "\n",
    "\n",
    "def prepare_ticker_data(ticker, start_date=START_DATE, end_date=END_DATE):\n",
    "    \"\"\"\n",
    "    Download data for ONE ticker and create features and target.\n",
    "    \"\"\"\n",
    "\n",
    "    # download single ticker – columns should be simple Index\n",
    "    data = yf.download(ticker, start=start_date, end=end_date, auto_adjust=False)\n",
    "\n",
    "    if data is None or data.empty:\n",
    "        print(f\"No data for {ticker}\")\n",
    "        return None\n",
    "\n",
    "    # just in case yfinance returns MultiIndex columns\n",
    "    if isinstance(data.columns, pd.MultiIndex):\n",
    "        data.columns = data.columns.get_level_values(0)\n",
    "\n",
    "    # daily return\n",
    "    data[\"Return\"] = data[\"Close\"].pct_change()\n",
    "\n",
    "    # next-day return as target\n",
    "    data[\"Target\"] = data[\"Return\"].shift(-1)\n",
    "\n",
    "    # moving averages\n",
    "    data[\"MA_5\"] = data[\"Close\"].rolling(5).mean()\n",
    "    data[\"MA_10\"] = data[\"Close\"].rolling(10).mean()\n",
    "    data[\"MA_20\"] = data[\"Close\"].rolling(20).mean()\n",
    "\n",
    "    # volatility (std of returns)\n",
    "    data[\"Vol_10\"] = data[\"Return\"].rolling(10).std()\n",
    "    data[\"Vol_20\"] = data[\"Return\"].rolling(20).std()\n",
    "\n",
    "    # RSI\n",
    "    data[\"RSI_14\"] = compute_rsi(data[\"Close\"], period=14)\n",
    "\n",
    "    # add ticker label\n",
    "    data[\"Ticker\"] = ticker\n",
    "\n",
    "    # drop NaNs caused by rolling and shifting\n",
    "    data = data.dropna()\n",
    "\n",
    "    return data\n"
   ]
